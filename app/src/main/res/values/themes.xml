<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Kitsune" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/kitsune_orange</item>
        <item name="android:windowBackground">@color/kitsune_background</item>
        <item name="android:statusBarColor">@color/kitsune_background</item>
        <item name="android:navigationBarColor">@color/kitsune_background</item>
    </style>

    <style name="Theme.Kitsune" parent="Base.Theme.Kitsune" />

    <!-- Splash Screen Theme -->
    <style name="Theme.Kitsune.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/kitsune_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_v12</item>
        <item name="postSplashScreenTheme">@style/Theme.Kitsune</item>
    </style>
</resources>